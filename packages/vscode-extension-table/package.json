{
  "name": "entaula",
  "displayName": "EnTaula",
  "description": "Edición de celdas multilínea, autoajuste y navegación inteligente para tablas ASCII y geométricas.",
  "version": "1.0.2",
  "publisher": "gerardfp",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gerardfp/EnTaula"
  },
  "license": "GPL-3.0-or-later",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:edumark",
    "onLanguage:markdown",
    "onLanguage:plaintext"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "edumark",
        "aliases": [
          "EduMark",
          "edumark"
        ],
        "extensions": [
          ".edu"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "edumark",
        "scopeName": "source.edu",
        "path": "./syntaxes/edumark.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "entaula.tableEnter",
        "title": "EnTaula: Insertar nueva línea en celda de tabla",
        "category": "EnTaula"
      },
      {
        "command": "entaula.tableTab",
        "title": "EnTaula: Autoformatear layout de tabla con la tecla º",
        "category": "EnTaula"
      },
      {
        "command": "entaula.selectCellContent",
        "title": "EnTaula: Seleccionar contenido completo de celda de tabla",
        "category": "EnTaula"
      },
      {
        "command": "entaula.convertToMarkdown",
        "title": "EnTaula: Convertir tabla EnTaula a Markdown",
        "category": "EnTaula"
      },
      {
        "command": "entaula.convertToEnTaula",
        "title": "EnTaula: Convertir tabla Markdown a EnTaula",
        "category": "EnTaula"
      }
    ],
    "keybindings": [
      {
        "command": "entaula.tableEnter",
        "key": "enter",
        "when": "editorTextFocus && (editorLangId == edumark || editorLangId == markdown || editorLangId == plaintext || resourceExtname == .edu || resourceExtname == .md || resourceExtname == .txt)"
      },
      {
        "command": "entaula.tableTab",
        "key": "oem_5",
        "when": "editorTextFocus && (editorLangId == edumark || editorLangId == markdown || editorLangId == plaintext || resourceExtname == .edu || resourceExtname == .md || resourceExtname == .txt)"
      },
      {
        "command": "entaula.cursorRightSelect",
        "key": "shift+right",
        "when": "editorTextFocus && entaula.isInTableCell"
      },
      {
        "command": "entaula.cursorLeftSelect",
        "key": "shift+left",
        "when": "editorTextFocus && entaula.isInTableCell"
      },
      {
        "command": "entaula.cursorDownSelect",
        "key": "shift+down",
        "when": "editorTextFocus && entaula.isInTableCell"
      },
      {
        "command": "entaula.cursorUpSelect",
        "key": "shift+up",
        "when": "editorTextFocus && entaula.isInTableCell"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npx esbuild ./src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=./dist/extension.js",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@edumark/shared": "*",
    "@edumark/table-engine": "*"
  }
}