{
  "name": "ataula-vscode-extension",
  "displayName": "Ataula",
  "description": "Multi-line cell editing, auto-resize, and smart selection for text and Markdown tables.",
  "version": "1.0.7",
  "publisher": "gerardfp",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gerardfp/Ataula"
  },
  "license": "GPL-3.0-or-later",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:edumark",
    "onLanguage:markdown",
    "onLanguage:plaintext"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "edumark",
        "aliases": [
          "EduMark",
          "edumark"
        ],
        "extensions": [
          ".edu"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "edumark",
        "scopeName": "source.edu",
        "path": "./syntaxes/edumark.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "ataula.tableEnter",
        "title": "Ataula: Insertar nueva línea en celda de tabla",
        "category": "Ataula"
      },
      {
        "command": "ataula.tableTab",
        "title": "Ataula: Autoformatear layout de tabla con la tecla º",
        "category": "Ataula"
      },
      {
        "command": "ataula.selectCellContent",
        "title": "Ataula: Seleccionar contenido completo de celda de tabla",
        "category": "Ataula"
      },
      {
        "command": "ataula.convertToMarkdown",
        "title": "Ataula: Convertir tabla Ataula a Markdown",
        "category": "Ataula"
      },
      {
        "command": "ataula.convertToAtaula",
        "title": "Ataula: Convertir tabla Markdown a Ataula",
        "category": "Ataula"
      }
    ],
    "keybindings": [
      {
        "command": "ataula.tableEnter",
        "key": "enter",
        "when": "editorTextFocus && (editorLangId == edumark || editorLangId == markdown || editorLangId == plaintext || resourceExtname == .edu || resourceExtname == .md || resourceExtname == .txt)"
      },
      {
        "command": "ataula.tableTab",
        "key": "oem_5",
        "when": "editorTextFocus && (editorLangId == edumark || editorLangId == markdown || editorLangId == plaintext || resourceExtname == .edu || resourceExtname == .md || resourceExtname == .txt)"
      },
      {
        "command": "ataula.cursorRightSelect",
        "key": "shift+right",
        "when": "editorTextFocus && ataula.isInTableCell"
      },
      {
        "command": "ataula.cursorLeftSelect",
        "key": "shift+left",
        "when": "editorTextFocus && ataula.isInTableCell"
      },
      {
        "command": "ataula.cursorDownSelect",
        "key": "shift+down",
        "when": "editorTextFocus && ataula.isInTableCell"
      },
      {
        "command": "ataula.cursorUpSelect",
        "key": "shift+up",
        "when": "editorTextFocus && ataula.isInTableCell"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npx esbuild ./src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=./dist/extension.js",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@edumark/shared": "*",
    "@edumark/table-engine": "*"
  }
}